{
  "name": "graphql-gene-monorepo",
  "version": "0.0.0",
  "description": "Generates automatically an executable schema out of your ORM models",
  "repository": "accesimpot/graphql-gene",
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "engines": {
    "node": "^12.22.0 || ^14.16.0 || ^16.0.0 || >=17.0.0"
  },
  "scripts": {
    "dev": "pnpm playground dev",
    "build": "TURBO_TELEMETRY_DISABLED=1 turbo run build",
    "lint": "pnpm lint:all",
    "lint:fix": "pnpm lint:all:fix",
    "lint:all": "pnpm lint:base .",
    "lint:all:fix": "pnpm lint:all --fix",
    "lint:affected": "pnpm lint:base $(git diff --name-only --diff-filter=d origin/main | grep -E \"\\.[mc]?[jt]s$\" | xargs)",
    "lint:affected:fix": "pnpm lint:affected --fix",
    "lint:base": "eslint --cache",
    "format": "prettier --write --cache \"**/*.{js,mjs,cjs,ts,mts,cts,json,yaml,yml,gql,graphql,md}\"",
    "format:check": "prettier --check --cache \"**/*.{js,mjs,cjs,ts,mts,cts,json,yaml,yml,gql,graphql,md}\"",
    "types:check": "TURBO_TELEMETRY_DISABLED=1 turbo run types:check",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:inspect": "vitest --inspect-brk=0.0.0.0:8806 --no-file-parallelism",
    "test:non-cacheable": "vitest --run --config vitest.always.config.ts",
    "dev-utils": "TURBO_TELEMETRY_DISABLED=1 turbo run --filter=dev-utils",
    "dev-utils:": "pnpm -F=dev-utils",
    "playground": "TURBO_TELEMETRY_DISABLED=1 turbo run --filter=dev-playground",
    "playground:": "pnpm -F=dev-playground",
    "core": "TURBO_TELEMETRY_DISABLED=1 turbo run --filter=graphql-gene",
    "core:": "pnpm -F=graphql-gene",
    "sequelize": "TURBO_TELEMETRY_DISABLED=1 turbo run --filter=@graphql-gene/plugin-sequelize",
    "sequelize:": "pnpm -F=@graphql-gene/plugin-sequelize"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.7",
    "@eslint/js": "^9.32.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/eslint__js": "^9.14.0",
    "@vitest/coverage-istanbul": "^4.1.5",
    "dev-utils": "workspace:*",
    "eslint": "^9.32.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "turbo": "^2.9.6",
    "prettier": "^3.5.3",
    "semantic-release": "^25.0.3",
    "semantic-release-monorepo": "^8.0.2",
    "sqlite3": "^6.0.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vitest": "^4.1.5"
  }
}
