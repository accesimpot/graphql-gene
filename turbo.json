{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:cjs": {
      "dependsOn": ["^build"],
      "outputs": ["cjs/**"]
    },
    "build:deps": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "types:check": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "//#vitest:run": {
      "dependsOn": ["dev-utils#build"],
      "outputs": []
    },
    "//#vitest:watch": {
      "dependsOn": ["dev-utils#build"],
      "cache": false,
      "persistent": true
    },
    "//#vitest:inspect": {
      "dependsOn": ["dev-utils#build"],
      "cache": false,
      "persistent": true
    },
    "//#vitest:always": {
      "dependsOn": ["dev-utils#build", "graphql-gene#build:deps"],
      "outputs": []
    }
  }
}
